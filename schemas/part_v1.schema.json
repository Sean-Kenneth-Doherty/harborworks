{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harborworks.local/schemas/part_v1.schema.json",
  "title": "Harborworks Beam Part v1",
  "type": "object",
  "required": [
    "schema_version",
    "part_id",
    "display_name",
    "category",
    "outer_diameter_m",
    "wall_thickness_m",
    "cost_each"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "part_id": { "type": "string", "minLength": 1 },
    "display_name": { "type": "string", "minLength": 1 },
    "category": { "type": "string", "minLength": 1 },
    "outer_diameter_m": { "type": "number", "minimum": 0 },
    "wall_thickness_m": { "type": "number", "minimum": 0 },
    "cost_each": { "type": "number", "minimum": 0 }
  }
}
